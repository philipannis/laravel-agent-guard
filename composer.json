{
  "name": "philipannis/laravel-agent-guard",
  "description": "Stop leaking secrets to local AI agents. This plugin moves .env variables into macOS keychain and loads them securely at runtime with zero changes to your app.",
  "type": "composer-plugin",
  "license": "MIT",
  "keywords": [
    "agent",
    "ai",
    "env",
    "environment",
    "guard",
    "keychain",
    "laravel",
    "macos",
    "sandbox",
    "secrets"
  ],
  "require": {
    "php": "^8.1",
    "composer-plugin-api": "^2.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "PhilipAnnis\\LaravelAgentGuard\\": "src/"
    },
    "files": [
      "src/Bootstrap.php"
    ]
  },
  "extra": {
    "class": "PhilipAnnis\\LaravelAgentGuard\\Plugin"
  }
}